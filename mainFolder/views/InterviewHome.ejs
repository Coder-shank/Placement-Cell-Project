<head>
  <%- include('_bootstrap_meta')%>

  <title>Interview Dashboard</title>

  <style>
    body {
      background: linear-gradient(to right, #dbeafe, #f0fdfa);
      font-family: Arial, Helvetica, sans-serif;
      margin: 0;
      padding: 30px;
    }

    .container {
      width: 75%;
      margin: auto;
      background-color: white;
      padding: 35px;
      border-radius: 18px;
      box-shadow: 0px 8px 25px rgba(0, 0, 0, 0.12);
    }

    h1 {
      text-align: center;
      color: #1e3a8a;
      margin-bottom: 35px;
      font-weight: bold;
    }

    .top-btn {
      display: inline-block;
      text-decoration: none;
      background: linear-gradient(to right, #2563eb, #1d4ed8);
      color: white;
      padding: 14px 24px;
      border-radius: 12px;
      font-size: 16px;
      font-weight: bold;
      transition: 0.3s ease;
      margin-bottom: 30px;
    }

    .top-btn:hover {
      transform: translateY(-3px);
      box-shadow: 0px 8px 20px rgba(37, 99, 235, 0.35);
    }

    .interview-list {
      list-style: none;
      padding: 0;
    }

    .interview-item {
      background-color: #f8fafc;
      margin-bottom: 18px;
      padding: 20px;
      border-radius: 14px;
      border-left: 6px solid #2563eb;
      transition: 0.3s ease;
    }

    .interview-item:hover {
      transform: translateX(5px);
      background-color: #eff6ff;
      box-shadow: 0px 5px 15px rgba(0, 0, 0, 0.1);
    }

    .interview-link {
      text-decoration: none;
      color: #1e293b;
      font-size: 18px;
      font-weight: bold;
    }

    @media (max-width: 768px) {
      .container {
        width: 95%;
        padding: 20px;
      }
    }
  </style>
</head>

<body>

  <div class="container">

    <h1>Interview Dashboard</h1>

    <a href="/Students/interviewForm" class="top-btn">
      Add Interview
    </a>

    <ul class="interview-list">

      <% for(let i of interview){ %>

        <li class="interview-item">

          <a href="/Students/InterviewHome/<%= i.id %>" class="interview-link">
            <%= i.Company_Name %>
          </a>

        </li>

      <% } %>

    </ul>

  </div>

</body>
